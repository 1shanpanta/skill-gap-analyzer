NODE_ENV=development
PORT=3000

# Database (use Supabase "Direct connection" URL for production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skill_gap_analyzer

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Gemini (free tier)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# LLM Skill Extraction (free with Gemini)
ENABLE_LLM_SKILL_EXTRACTION=false

# CORS (required in production)
FRONTEND_URL=

# GitHub (optional - for higher rate limits)
GITHUB_TOKEN=

# Rate Limiting
DAILY_ANALYSIS_LIMIT=5

# Worker
WORKER_POLL_INTERVAL_MS=2000
JOB_STALE_THRESHOLD_MINUTES=5
JOB_MAX_ATTEMPTS=3
