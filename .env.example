NODE_ENV=development
PORT=3000

# Database (use Supabase "Direct connection" URL for production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skill_gap_analyzer

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# LLM Skill Extraction (optional enhancement)
ENABLE_LLM_SKILL_EXTRACTION=false

# CORS (required in production)
FRONTEND_URL=

# GitHub (optional - for higher rate limits)
GITHUB_TOKEN=

# Google OAuth (optional - register at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Email via Resend (optional - register at resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Rate Limiting
DAILY_ANALYSIS_LIMIT=5

# Worker
WORKER_POLL_INTERVAL_MS=2000
JOB_STALE_THRESHOLD_MINUTES=5
JOB_MAX_ATTEMPTS=3
