{
  "name": "skill-gap-analyzer",
  "version": "1.0.0",
  "description": "Backend API for analyzing skill gaps between resumes and job descriptions",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -n api,web,open -c blue,green,yellow \"tsx watch src/index.ts\" \"cd client && bun run dev\" \"wait-on http://localhost:3001 && open http://localhost:3001\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:client": "cd client && bun run dev",
    "build": "bunx prisma generate && tsc",
    "start": "node dist/index.js",
    "postinstall": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wait-on": "^8.0.0"
  }
}
