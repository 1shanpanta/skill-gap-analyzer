generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String           @unique(map: "users_email_unique") @db.VarChar(255)
  name                   String           @db.VarChar(255)
  password_hash          String?          @db.VarChar(255)
  google_id              String?          @unique @db.VarChar(255)
  avatar_url             String?          @db.VarChar(500)
  password_reset_token   String?          @unique @db.VarChar(255)
  password_reset_expires DateTime?        @db.Timestamptz(6)
  daily_analysis_count   Int              @default(0)
  last_analysis_date     DateTime?        @db.Date
  created_at             DateTime         @default(now()) @db.Timestamptz(6)
  updated_at             DateTime         @default(now()) @db.Timestamptz(6)
  analyses               Analysis[]
  job_descriptions       JobDescription[]
  resumes                Resume[]

  @@map("users")
}

model Resume {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String     @db.Uuid
  raw_text       String
  extracted_data Json?
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  analyses       Analysis[]
  user           User       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "resumes_user_id_foreign")

  @@index([user_id], map: "resumes_user_id_index")
  @@map("resumes")
}

model JobDescription {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String     @db.Uuid
  raw_text       String
  extracted_data Json?
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  analyses       Analysis[]
  user           User       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "job_descriptions_user_id_foreign")

  @@index([user_id], map: "job_descriptions_user_id_index")
  @@map("job_descriptions")
}

model Analysis {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String         @db.Uuid
  resume_id          String         @db.Uuid
  job_description_id String         @db.Uuid
  status             String         @default("pending") @db.VarChar(20)
  overall_score      Decimal?       @db.Decimal(5, 2)
  score_breakdown    Json?
  skill_gaps         Json?
  github_signals     Json?
  roadmap            String?
  resume_suggestions String?
  token_usage        Json?
  github_url         String?        @db.VarChar(500)
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  completed_at       DateTime?      @db.Timestamptz(6)
  job_description    JobDescription @relation(fields: [job_description_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "analyses_job_description_id_foreign")
  resume             Resume         @relation(fields: [resume_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "analyses_resume_id_foreign")
  user               User           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "analyses_user_id_foreign")

  @@index([status], map: "analyses_status_index")
  @@index([user_id], map: "analyses_user_id_index")
  @@map("analyses")
}

model Job {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         String    @db.VarChar(50)
  status       String    @default("pending") @db.VarChar(20)
  payload      Json
  result       Json?
  attempts     Int       @default(0)
  max_attempts Int       @default(3)
  priority     Int       @default(0)
  scheduled_at DateTime  @default(now()) @db.Timestamptz(6)
  started_at   DateTime? @db.Timestamptz(6)
  completed_at DateTime? @db.Timestamptz(6)
  failed_at    DateTime? @db.Timestamptz(6)
  error        String?
  worker_id    String?   @db.VarChar(100)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)

  @@index([priority(sort: Desc), scheduled_at], map: "idx_jobs_claimable", where: raw("((status)::text = 'pending'::text)"))
  @@index([started_at], map: "idx_jobs_stale", where: raw("((status)::text = 'processing'::text)"))
  @@map("jobs")
}
